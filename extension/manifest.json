{
  "manifest_version": 3,
  "name": "redfin-surfer.seattle",
  "version": "1.0",
  "description": "Redfin due-diligence side panel scoped to Seattle and King County, WA.",
  "permissions": [
    "activeTab",
    "sidePanel",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://*.redfin.com/*",
    "https://data.seattle.gov/*",
    "https://gismaps.kingcounty.gov/*",
    "https://utility.arcgisonline.com/*",
    "https://*.on.aws/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.redfin.com/*"
      ],
      "js": [
        "shared/parser.js",
        "content.js"
      ],
      "run_at": "document_end",
      "all_frames": true,
      "match_origin_as_fallback": true
    }
  ],
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "action": {
    "default_title": "Open Diligence Sidecar"
  }
}
